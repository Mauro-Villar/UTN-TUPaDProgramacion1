energia = 100
tiempo = 12
cerraduras_abiertas = 0
alarma = False
codigo_parcial = ""

nombre = input("Ingresa el nombre del agente: ")

while nombre == "" or not nombre.isalpha():
    nombre = input("Error. Ingresa el nombre del agente: ")

forzar_seguidas = 0
bloqueado = False

while energia > 0 and tiempo > 0 and cerraduras_abiertas < 3 and bloqueado == False:
    print("\n----- ESTADO -----")
    print("Agente:", nombre)
    print("Energía:", energia)
    print("Tiempo:", tiempo)
    print("Cerraduras abiertas:", cerraduras_abiertas)
    print("Alarma:", alarma)
    print("Código parcial:", codigo_parcial)

    print("\n1. Forzar cerradura")
    print("2. Hackear panel")
    print("3. Descansar")

    opcion = input("Ingresa una opción: ")

    while not opcion.isdigit():
        opcion = input("Error. Ingresa una opción válida: ")

    opcion = int(opcion)

    if opcion == 1:
        forzar_seguidas += 1
        energia = energia - 20
        tiempo = tiempo - 2

        if forzar_seguidas == 3:
            alarma = True
            print("La cerradura se trabó. Se activó la alarma.")
        else:
            if energia < 40:
                numero = input("Riesgo de alarma. Ingresa un número del 1 al 3: ")

                while not numero.isdigit() or int(numero) < 1 or int(numero) > 3:
                    numero = input("Error. Ingresa un número del 1 al 3: ")

                numero = int(numero)

                if numero == 3:
                    alarma = True
                    print("Se activó la alarma.")

            if alarma == False:
                cerraduras_abiertas += 1
                print("Abriste una cerradura.")
            else:
                print("No se pudo abrir la cerradura.")

    elif opcion == 2:
        forzar_seguidas = 0
        energia = energia - 10
        tiempo = tiempo - 3

        for i in range(4):
            codigo_parcial = codigo_parcial + "A"
            print("Hackeo en progreso:", codigo_parcial)

        if len(codigo_parcial) >= 8 and cerraduras_abiertas < 3:
            cerraduras_abiertas += 1
            print("El panel fue hackeado. Se abrió una cerradura.")

    elif opcion == 3:
        forzar_seguidas = 0
        energia = energia + 15

        if energia > 100:
            energia = 100

        tiempo = tiempo - 1

        if alarma == True:
            energia = energia - 10
            print("La alarma sigue activa. Perdés 10 de energía extra.")

        print("Descansaste.")

    else:
        print("Opción incorrecta.")

    if alarma == True and tiempo <= 3 and cerraduras_abiertas < 3:
        bloqueado = True

if cerraduras_abiertas == 3:
    print("\nVICTORIA: abriste la bóveda.")
elif bloqueado == True:
    print("\nDERROTA: el sistema se bloqueó por la alarma.")
else:
    print("\nDERROTA: te quedaste sin energía o sin tiempo.")
