nombre = input("Ingresa el nombre del cliente: ")

while nombre == "" or not nombre.isalpha():
    nombre = input("Error. Ingresa el nombre del cliente solo con letras: ")

cantidad = input("Ingresa la cantidad de productos a comprar: ")

while not cantidad.isdigit() or int(cantidad) <= 0:
    cantidad = input("Error. Ingresa una cantidad mayor a 0: ")

cantidad = int(cantidad)

total_sin_descuento = 0
total_con_descuento = 0

for i in range(1, cantidad + 1):
    precio = input(f"Ingresa el precio del producto {i}: ")

    while not precio.isdigit():
        precio = input(f"Error. Ingresa un precio válido para el producto {i}: ")

    precio = int(precio)

    descuento = input(f"¿El producto {i} tiene descuento? (S/N): ")

    while descuento.lower() != "s" and descuento.lower() != "n":
        descuento = input(f"Error. Ingresa S o N para el producto {i}: ")

    total_sin_descuento += precio

    if descuento.lower() == "s":
        precio_con_descuento = precio * 0.9
    else:
        precio_con_descuento = precio

    total_con_descuento += precio_con_descuento

ahorro_total = total_sin_descuento - total_con_descuento
promedio_por_producto = total_con_descuento / cantidad

print("\nCliente:", nombre)
print("Cantidad de productos:", cantidad)
print(f"Total sin descuentos: ${total_sin_descuento}")
print(f"Total con descuentos: ${total_con_descuento:.2f}")
print(f"Ahorro total: ${ahorro_total:.2f}")
print(f"Promedio por producto: ${promedio_por_producto:.2f}")
